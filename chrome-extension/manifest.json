{
  "manifest_version": 3,
  "name": "APIpulse — AI API Price Checker",
  "version": "1.0.0",
  "description": "Instantly check AI API pricing for 39 models across 10 providers. Compare costs and estimate your monthly bill.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
